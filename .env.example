# ==============================================================================
# Vision-Pulse — Environment Configuration
# ==============================================================================
# Renamed this file to `.env` and fill in the values below.

# ------------------------------------------------------------------------------
# API Keys (External Services)
# ------------------------------------------------------------------------------
# Google Gemini (Primary Image Generation - gemini-2.5-flash-image)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (Image Prompts, Subtitles, Image Fallback, TTS Fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs (Primary Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ------------------------------------------------------------------------------
# Database & Worker Infrastructure
# ------------------------------------------------------------------------------
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/vision_pulse
DATABASE_URL=postgresql://user:password@localhost:5432/vision_pulse

# Redis connection string for Celery Broker
# Example: redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis connection string for Celery Result Backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------
# Secret key for JWT Token Generation (generate using: openssl rand -hex 32)
SECRET_KEY=your_super_secret_key_here

# JWT Token Expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------------------------
# Default is set for Gmail. For Gmail, use an "App Password" rather than your real password.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=Vision-Pulse <noreply@visionpulse.com>

# ------------------------------------------------------------------------------
# Application configuration
# ------------------------------------------------------------------------------
# Video configuration overrrides (matches VIDEO_GENERATION.md defaults)
DEFAULT_FPS=30
ENABLE_SUBTITLES=True
SUBTITLE_MODEL=gpt-4o-mini
CAMERA_ZOOM_INTENSITY=0.15
CAMERA_ENABLE_ROTATION=False
CAMERA_PAN_HORIZONTAL_MAX=0.08
CAMERA_PAN_VERTICAL_MAX=0.04
IMAGE_COUNT=7
MAX_SCRIPT_LENGTH=1500

# Job Queue limits
MAX_CONCURRENT_JOBS=10
MAX_QUEUED_JOBS=10
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=60
